# PennyCentral environment template
# Copy to .env.local for local development.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Report submit safety
# true  => validate-only mode for /api/submit-find (no DB writes, no SERPAPI usage)
# false => live writes enabled
# default behavior: auto-enabled in local development when unset
SUBMIT_FIND_DRY_RUN=

# Visual pointer developer tool safety
# Default behavior:
# - disabled on production deployment
# - enabled in local development and preview environments
# Optional override:
# - true  => force-enable
# - false => force-disable
NEXT_PUBLIC_VISUAL_POINTER_ENABLED=

# Admin moderation APIs (/api/admin/*)
ADMIN_SECRET=

# Vercel cron endpoint auth
CRON_SECRET=

# Email delivery
RESEND_API_KEY=
NEXT_PUBLIC_SITE_URL=https://www.pennycentral.com

# Analytics kill switch
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Monumetric runtime kill switch (emergency UX protection)
# false => disable Monumetric script + in-content slots
# true  => enable Monumetric runtime
NEXT_PUBLIC_MONUMETRIC_ENABLED=false
