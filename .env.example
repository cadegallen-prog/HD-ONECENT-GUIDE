# PennyCentral environment template
# Copy to .env.local for local development.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Report submit safety
# true  => validate-only mode for /api/submit-find (no DB writes, no SERPAPI usage)
# false => live writes enabled
# default behavior: auto-enabled in local development when unset
SUBMIT_FIND_DRY_RUN=

# Visual pointer developer tool safety
# Default behavior:
# - disabled on production deployment
# - enabled in local development and preview environments
# Optional override:
# - true  => force-enable
# - false => force-disable
NEXT_PUBLIC_VISUAL_POINTER_ENABLED=

# Admin moderation APIs (/api/admin/*)
ADMIN_SECRET=

# Vercel cron endpoint auth
CRON_SECRET=

# Email delivery
RESEND_API_KEY=
NEXT_PUBLIC_SITE_URL=https://www.pennycentral.com

# Analytics kill switch
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Monumetric runtime kill switch (emergency UX protection)
# false => disable Monumetric script + in-content slots
# true  => enable Monumetric runtime
NEXT_PUBLIC_MONUMETRIC_ENABLED=false

# SerpApi budget policy (scheduled enrichment fallback)
# Defaults below are conservative and designed to avoid runaway month rollover.
SERPAPI_MONTHLY_CAP=250
SERPAPI_MONTHLY_RESERVE=10
SERPAPI_MIN_DAILY_CREDITS=4
SERPAPI_MAX_DAILY_CREDITS=12
SERPAPI_MAX_CREDITS_PER_RUN=6
SERPAPI_ESTIMATED_CREDITS_PER_ITEM=3
SERPAPI_BILLING_RESET_ANCHOR_ISO=2026-03-18T00:00:00.000Z
SERPAPI_BACKFILL_WINDOW_MINUTES_BEFORE_RESET=360
SERPAPI_LATE_MONTH_HIGH_REMAINING_CREDITS=45
SERPAPI_LATE_MONTH_BACKFILL_DAILY_CAP=28
SERPAPI_LATE_MONTH_BACKFILL_MAX_RUN_CREDITS=14
SERPAPI_PRE_RESET_GUARD_MINUTES=60
SERPAPI_POST_RESET_GUARD_MINUTES=60
SERPAPI_STALE_ESCALATION_MINUTES=120
